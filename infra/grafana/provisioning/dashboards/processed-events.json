{
  "uid": "processed-events",
  "title": "Processed Events Analytics",
  "tags": ["memcyco", "assignment"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "barchart",
      "title": "Count events by type",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-warehouse" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT event_type AS type, COUNT(*)::bigint AS count\nFROM processed_events\nGROUP BY event_type\nORDER BY COUNT(*) DESC;"
        }
      ],
      "options": {
        "xField": "type",
        "yField": "count",
        "orientation": "horizontal",
        "showValue": "always"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Latest processed records (20)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "postgres-warehouse" },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawSql": "SELECT id, event_type, event_time, source, image_object_key, inserted_at\nFROM processed_events\nORDER BY inserted_at DESC\nLIMIT 20;"
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Events by hour (by type)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "datasource": { "type": "postgres", "uid": "postgres-warehouse" },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawSql": "SELECT date_trunc('hour', event_time) AS time,\n       COUNT(*)::bigint AS value,\n       event_type AS metric\nFROM processed_events\nWHERE $__timeFilter(event_time)\nGROUP BY 1, 3\nORDER BY 1;"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    }
  ]
}
